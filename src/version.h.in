#ifndef REAPER_AAF_VERSION_H
#define REAPER_AAF_VERSION_H

#define REAAF_VERSION_MAJOR @PROJECT_VERSION_MAJOR@
#define REAAF_VERSION_MINOR @PROJECT_VERSION_MINOR@
#define REAAF_VERSION_PATCH @PROJECT_VERSION_PATCH@
#define REAAF_VERSION_STRING "@PROJECT_VERSION@"

#ifdef _MSC_VER
__declspec(selectany) extern const char REAAF_VERSION_STAMP[] = "@reAAF_VERSION: " REAAF_VERSION_STRING "@";
#else
const char REAAF_VERSION_STAMP[] __attribute((used)) = "@reAAF_VERSION: " REAAF_VERSION_STRING "@";
#endif //_MSC_VER

#endif //REAPER_AAF_VERSION_H